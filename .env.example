# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=your-bot-token-here

# Your Telegram user ID (send /myid to @userinfobot to get it)
AUTHORIZED_USER_ID=123456789

# Local API port for TUI (default: 7777)
API_PORT=7777

# AI runtime provider (default: copilot)
AI_PROVIDER=copilot

# Default AI model (backward-compatible fallback: COPILOT_MODEL)
AI_MODEL=claude-sonnet-4.6

# Mastra example:
# AI_PROVIDER=mastra
# AI_MODEL=openai/gpt-4.1
# CLASSIFIER_MODEL=openai/gpt-4.1
# OPENAI_API_KEY=your-openai-api-key
#
# Other provider keys Mastra can use depending on AI_MODEL:
# ANTHROPIC_API_KEY=your-anthropic-api-key
# GOOGLE_GENERATIVE_AI_API_KEY=your-google-api-key
# MINIMAX_API_KEY=your-minimax-api-key
# XAI_API_KEY=your-xai-api-key
# OPENROUTER_API_KEY=your-openrouter-api-key

# Dedicated classifier model for auto-routing (default: gpt-4.1)
CLASSIFIER_MODEL=gpt-4.1

# Worker timeout in milliseconds (default: 600000)
WORKER_TIMEOUT=600000

# Optional assistant heartbeat (default: disabled with 0m)
# Examples: 15m, 30m, 1h, 45s
HEARTBEAT_EVERY=0m

# Where heartbeat alerts should be delivered: none | telegram | tui | all
HEARTBEAT_TARGET=none

# How much initiative heartbeat may take: observe | notify | act
HEARTBEAT_AUTONOMY=observe

# Optional active-hours window for heartbeat, using local time
# Format: HH:MM-HH:MM
# HEARTBEAT_ACTIVE_HOURS=08:00-22:00

# Legacy fallback still honored if AI_MODEL is unset
# COPILOT_MODEL=claude-sonnet-4.6
